<body>
  <main>
    <form method="POST" action="/game/form">
      <div>
        <label for="title">Title </label>
        <input type="text" name="title" id="title" />
      </div>
      <div>
        <label for="description">Description </label>
        <textarea type="text" name="description" id="description"></textarea>
      </div>
      <div>
        <label for="price">Price </label>
        <input type="number" name="price" id="price" />
      </div>
      <div>
        <label for="rating">Rating </label>
        <input type="number" max="10" min="1" name="rating" id="rating" />
      </div>
      <div>
        <label for="genres">Select Genres (Use cmd/ctrl to select multiple) </label>
        <select name="genres" id="genres" multiple>
          <% for (let i = 0; i < genres.length; i++) { %>
            <option value="<%= genres[i].genre %>"><%= genres[i].genre %></option>
          <% } %>
        </select>
      </div>
      <div>
        <label for="devs">Select Developers (Use cmd/ctrl to select multiple) </label>
        <select name="devs" id="devs" multiple>
          <% for (let i = 0; i < devs.length; i++) { %>
            <option value="<%= devs[i].developer %>"><%= devs[i].developer %></option>
          <% } %>
        </select>
      </div>

      <input type="submit" value="Submit" />
    </form>
  </main>
</body>
